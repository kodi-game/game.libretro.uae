From ab6c6c3de582c0a7ce98f1e85aa5b180bde47bc8 Mon Sep 17 00:00:00 2001
From: Garrett Brown <themagnificentmrb@gmail.com>
Date: Mon, 11 May 2026 17:34:16 -0700
Subject: [PATCH 1/2] fix: Correct fseek error check in my_fsize

This change treats seek failure as `< 0` in file size check.

`my_fsize()` was treating non-zero seek results as failure, but the wrapped
seek API may return the new position on success. Check for negative return
values instead to avoid false "fseek failed" errors and restore WHDLoad
startup script execution.
---
 retrodep/fsdb_host.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/retrodep/fsdb_host.c b/retrodep/fsdb_host.c
index 9a3e306c..28533845 100644
--- a/retrodep/fsdb_host.c
+++ b/retrodep/fsdb_host.c
@@ -428,7 +428,7 @@ uae_s64 my_fsize(struct my_openfile_s* mos) {
 #else
 	size_t size = 0;
 	int current = ftell(mos->fp);
-	if (fseek(mos->fp, 0, SEEK_END)) {
+	if (fseek(mos->fp, 0, SEEK_END) < 0) {
 		write_log("my_fsize: fseek on file '%s' failed\n", mos->path);
 		return -1;
 	}
